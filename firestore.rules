rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile validation and access rules
    match /users/{userId} {
      allow read: if true; // Publicly readable for leaderboards
      allow write, update: if request.auth != null && request.auth.uid == userId;
      
      match /transactions/{txnId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Tournaments read/write rules
    match /tournaments/{date} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /participants/{participantId} {
        allow read: if true;
        allow write, update: if request.auth != null && request.auth.uid == participantId;
      }
    }
  }
}
